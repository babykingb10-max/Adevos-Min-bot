# ============================================================
# Adevos Min-Bot — Environment Variables Template
# Copy this file and rename it to ".env"
# Fill in your actual values below.
# NEVER commit the .env file to GitHub.
# ============================================================

# ─── MongoDB ─────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/adevosminbot

# ─── Telegram Bot ────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Admin Telegram user IDs (comma-separated, no spaces)
# Get your ID from @userinfobot on Telegram
ADMIN_IDS=123456789,987654321

# ─── Server Identity ─────────────────────────────────────────
# Name shown in admin panel and stats
SERVER_NAME=Main Server

# Maximum number of concurrent WhatsApp sessions
# Free Render tier (512MB RAM) handles ~100 comfortably
MAX_CONNECTIONS=100

# ─── WhatsApp ────────────────────────────────────────────────
# Default bot phone number (used in pair.js if needed)
BOT_PHONE_NUMBER=255712345678

# ─── Website Admin Panel ─────────────────────────────────────
# Login credentials for /admin page
ADMIN_USERNAME=Adevos
ADMIN_PASSWORD=your_strong_password_here

# JWT secret — use a long random string (min 32 characters)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_jwt_secret_here_min_32_chars

# ─── Telegram Bot URL (shown on website) ─────────────────────
TG_BOT_URL=https://t.me/your_bot_username

# ─── Cross-Service Communication (optional) ──────────────────
# Only needed if website and bot are on SEPARATE Render services.
# If they are on the same service, leave these commented out.

# BOT_WEBHOOK_URL=https://your-bot-service.onrender.com
# INTERNAL_SECRET=your_internal_secret_here

# ─── Optional ────────────────────────────────────────────────
# Tenor API key for /gif command in Telegram bot
# Get free key from: https://developers.google.com/tenor
# TENOR_API_KEY=your_tenor_api_key

PORT=3000

